{
  "version": "0.2.0",
  "configurations": [
    {
      // This launches a second VSCode window (Extension Development Host)
      // with your extension loaded and a debugger attached.
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      // Compile TS before launching so you always run fresh code
      "preLaunchTask": "npm: compile",
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "sourceMaps": true
    }
  ]
}
